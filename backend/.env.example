# ============================
# CẤU HÌNH ỨNG DỤNG
# ============================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost

# ============================
# DATABASE - PostgreSQL
# ============================
# Để chạy local: DB_HOST=localhost
# Để chạy Docker: DB_HOST=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=smart_booking
DB_USER=booking_user
DB_PASSWORD=booking_pass_2024
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================
# XÁC THỰC JWT
# ============================
# Cần thay đổi thành chuỗi ngẫu nhiên dài ít nhất 64 ký tự
JWT_SECRET=your_super_secret_jwt_key_at_least_64_characters_long_change_this_in_production_now
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_at_least_64_characters_long_change_this_too

# ============================
# UPLOAD FILES
# ============================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
MAX_UPLOAD_FILES=10
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# ============================
# CORS & SECURITY
# ============================
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ============================
# THANH TOÁN - MoMo Sandbox
# ============================
# Đăng ký tại: https://developers.momo.vn/
MOMO_PARTNER_CODE=MOMO_SANDBOX_PARTNER_CODE
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost/booking-confirm.html
MOMO_IPN_URL=http://your-server-domain.com/api/payment/momo-ipn

# ============================
# THANH TOÁN - VNPay Sandbox
# ============================
# Đăng ký tại: https://sandbox.vnpayment.vn/
VNPAY_ENABLED=false
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost/booking-confirm.html

# ============================
# THÔNG BÁO - Zalo ZNS
# ============================
# Đăng ký tại: https://developers.zalo.me/
ZALO_ENABLED=false
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
ZALO_ZNS_TEMPLATE_ID=your_zalo_zns_template_id

# ============================
# EMAIL (nếu cần gửi email)
# ============================
EMAIL_ENABLED=false
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@smartbooking.vn

# ============================
# LOGGING
# ============================
LOG_LEVEL=debug
LOG_DIR=./logs